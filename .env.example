# Copy this file to .env and fill in your values.
# .env is gitignored to prevent secrets from being committed.

# RabbitMQ credentials (defaults to guest/guest if not set)
RABBITMQ_USER=guest
RABBITMQ_PASS=guest

# DNSimple DNS settings (required for Pefi.DynamicDNS)
DNS_DOMAIN=your-domain.com
DNS_HOME_HOSTNAME=home.your-domain.com
DNS_API_TOKEN=your-dnsimple-api-token
DNS_CHECK_INTERVAL_MINUTES=2
